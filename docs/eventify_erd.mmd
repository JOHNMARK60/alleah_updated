erDiagram
    USERS ||--o{ RESERVATIONS : creates
    USERS ||--o{ NOTIFICATIONS : receives
    USERS ||--o{ ACTIVITY_LOGS : performs
    USERS ||--o{ EVENT_LOGS : records

    EVENT_PACKAGES ||--o{ PACKAGE_FEATURES : has
    EVENT_PACKAGES ||--o{ RESERVATIONS : selected_for
    EVENT_PACKAGES ||--o{ EVENTS : used_for
    EVENT_PACKAGES ||--o{ RESERVATION_ITEMS : priced_by

    RESERVATIONS ||--o| EVENTS : becomes
    RESERVATIONS ||--o{ PAYMENTS : has
    RESERVATIONS ||--o{ RESERVATION_STATUS_HISTORY : tracks
    RESERVATIONS ||--o{ RESERVATION_ITEMS : contains
    RESERVATIONS ||--o{ RESERVATION_SERVICES : includes
    SERVICE_OPTIONS ||--o{ RESERVATION_SERVICES : selected

    EVENTS ||--o{ EVENT_SERVICES : includes
